{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1JIxAdqWe3s-ezLGkWTOwqe1BL2igoLV5","timestamp":1774105528413},{"file_id":"1cz5maWn6X7F25p-LN4pJccFRnDaqD5WX","timestamp":1774105484452}],"authorship_tag":"ABX9TyMe0LT7PmBZFc0SdWb5lc6l"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["Лабораторная работа 1\n","\n","Выполнил студент группы ИДБ-25-07\n","\n","Пехтерев Иван"],"metadata":{"id":"t2jfXD03rmfE"}},{"cell_type":"markdown","source":["1. Проверка наличия элемента в массиве"],"metadata":{"id":"2ir0wJKrwPTc"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"nlZ7TAUJrLS0"},"outputs":[],"source":["def contains(arr, x):\n","    for el in arr:\n","        if el == x:\n","            return True\n","    return False"]},{"cell_type":"markdown","source":["2. Поиск второго максимального элемента"],"metadata":{"id":"qtsIvE6xwl4H"}},{"cell_type":"code","source":["def second_max(arr):\n","    max1 = max2 = float('-inf')\n","\n","    for x in arr:\n","        if x > max1:\n","            max2 = max1\n","            max1 = x\n","        elif x > max2 and x != max1:\n","            max2 = x\n","\n","    return max2"],"metadata":{"id":"1hWUJO1CwuLm"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["3. Бинарный поиск"],"metadata":{"id":"CMBAWd_HxtPV"}},{"cell_type":"code","source":["def binary_search(arr, x):\n","    left, right = 0, len(arr) - 1\n","\n","    while left <= right:\n","        mid = (left + right) // 2\n","\n","        if arr[mid] == x:\n","            return True\n","        elif arr[mid] < x:\n","            left = mid + 1\n","        else:\n","            right = mid - 1\n","\n","    return False"],"metadata":{"id":"pxL4dtEpxwV9"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["4. Построение таблицы умножения"],"metadata":{"id":"_4GTIrmezgYW"}},{"cell_type":"code","source":["def multiplication_table(n):\n","    table = []\n","    for i in range(1, n + 1):\n","        row = []\n","        for j in range(1, n + 1):\n","            row.append(i * j)\n","        table.append(row)\n","    return table"],"metadata":{"id":"5HsAAWjl0TCb"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":[" 5. Функция измерения времени"],"metadata":{"id":"P0TGr1-a0VXF"}},{"cell_type":"code","source":["import time\n","\n","def measure_time(func, *args):\n","    start = time.perf_counter()\n","    func(*args)\n","    end = time.perf_counter()\n","    return end - start"],"metadata":{"id":"M3DxeRvD0m4Z"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":[" 6. Функция генерации данных"],"metadata":{"id":"ZWDoJkW90qa_"}},{"cell_type":"code","source":["import random\n","\n","def generate_array(n):\n","    arr = []\n","    for i in range(n):\n","        arr.append(random.randint(0, 10000))\n","    return arr\n"],"metadata":{"id":"c_Cs_NfF0vhn"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":[" 7. Эксперимент"],"metadata":{"id":"uYpxV6XK06Hi"}},{"cell_type":"code","source":["import time\n","import random\n","\n","def contains(arr, x):\n","    for el in arr:\n","        if el == x:\n","            return True\n","    return False\n","\n","def second_max(arr):\n","    max1 = max2 = float('-inf')\n","\n","    for x in arr:\n","        if x > max1:\n","            max2 = max1\n","            max1 = x\n","        elif x > max2 and x != max1:\n","            max2 = x\n","    return max2\n","\n","def binary_search(arr, x):\n","    left, right = 0, len(arr) - 1\n","\n","    while left <= right:\n","        mid = (left + right) // 2\n","\n","        if arr[mid] == x:\n","            return True\n","        elif arr[mid] < x:\n","            left = mid + 1\n","        else:\n","            right = mid - 1\n","    return False\n","\n","def multiplication_table(n):\n","    table = []\n","    for i in range(1, n + 1):\n","        row = []\n","        for j in range(1, n + 1):\n","            row.append(i * j)\n","        table.append(row)\n","    return table\n","\n","def generate_array(n):\n","    return [random.randint(0, 10000) for _ in range(n)]\n","\n","def measure_time(func, *args):\n","    start = time.perf_counter()\n","    func(*args)\n","    end = time.perf_counter()\n","    return end - start\n","\n","\n","if __name__ == '__main__':\n","    sizes = [100, 1000, 5000, 10000]\n","\n","    for n in sizes:\n","        arr = generate_array(n)\n","        x = random.choice(arr)\n","\n","        t = measure_time(contains, arr, x)\n","        print(\"Проверка наличия элемента:\", n, t)\n","\n","        t = measure_time(second_max, arr)\n","        print(\"Второй максимум:\", n, t)\n","\n","        sorted_arr = sorted(arr)\n","        t = measure_time(binary_search, sorted_arr, x)\n","        print(\"Бинарный поиск:\", n, t)\n","\n","        t = measure_time(multiplication_table, n)\n","        print(\"Таблица умножения:\", n, t)\n","\n","        print(\"\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"BxhtPhEV2JuK","executionInfo":{"status":"ok","timestamp":1774105132184,"user_tz":-180,"elapsed":22935,"user":{"displayName":"Иван Пехтерев","userId":"16249190489397465055"}},"outputId":"498cf4e0-50c9-4c71-e62f-4c0a8d88c1a2"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Проверка наличия элемента: 100 3.427000024203153e-06\n","Второй максимум: 100 9.857000009105832e-06\n","Бинарный поиск: 100 4.006999915873166e-06\n","Таблица умножения: 100 0.0008521459999428771\n","\n","Проверка наличия элемента: 1000 5.385999997997715e-06\n","Второй максимум: 1000 3.4838000033232674e-05\n","Бинарный поиск: 1000 4.165000063949265e-06\n","Таблица умножения: 1000 0.16409743999997772\n","\n","Проверка наличия элемента: 5000 1.7581000065547414e-05\n","Второй максимум: 5000 0.0003193520000195349\n","Бинарный поиск: 5000 6.991000077505305e-06\n","Таблица умножения: 5000 5.579373808000014\n","\n","Проверка наличия элемента: 10000 5.727899997509667e-05\n","Второй максимум: 10000 0.00032763499996235623\n","Бинарный поиск: 10000 5.8750000562213245e-06\n","Таблица умножения: 10000 17.17909849399996\n","\n"]}]}]}